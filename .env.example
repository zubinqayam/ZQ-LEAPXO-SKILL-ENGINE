# .env.example — Copy to .env.local and fill in values.
# NEVER commit .env.local to source control.

# Backend server port
PORT=8000

# Environment (development | production)
LEAPXO_ENV=development

# SQLCipher encryption key (leave empty for plain SQLite in development)
LEAPXO_DB_KEY=

# LLM provider API key (required in production)
LEAPXO_API_KEY=

# Redis password
REDIS_PASSWORD=changeme

# HMAC/JWT signing key
LEAPXO_SECRET_KEY=

# Feedback chatbot keyhole encryption key
LEAPXO_FEEDBACK_ENC_KEY=

# Tauri Stronghold vault token (set by Tauri IPC at runtime)
LEAPXO_VAULT_TOKEN=

# Telemetry rate limit (requests per minute per IP)
LEAPXO_TELEMETRY_RATE_LIMIT=60
